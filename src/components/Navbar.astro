---
import { SITE_TITLE, NAV_LINKS as links } from "@/consts";
---

<nav
  class="w-full z-[9999] py-4 px-4 bg-monster-dark/90 backdrop-blur-sm border-b border-monster/20"
>
  <div
    class="w-full grid gap-4 md:px-5 place-items-center grid-cols-1 md:flex md:justify-between md:px-4"
  >
    <a href="/">
      <div
        id="logo"
        class="font-monster pt-2 pb-1 !grid !place-items-center select-none leading-none uppercase tracking-widest text-monster hover:text-monster-dark hover:bg-monster bg-transparent border border-monster px-4 transition-all ease-in-out"
        style="text-shadow: 0 0 12px rgba(0,220,50,0.5);"
      >
        {SITE_TITLE}
      </div>
    </a>
    <div class="flex flex-wrap gap-4 md:pr-5 items-center">
      <span class="hidden md:block text-monster/40 font-mono">/</span>
      {
        links.map((link) => {
          const href =
            link.href ?? link.title.toLowerCase().replaceAll(" ", "-");
          const pathname = Astro.url.pathname.replace(
            import.meta.env.BASE_URL,
            "",
          );
          const subpath = pathname.match(/[^\/]+/g);
          const isActive =
            href === pathname || href === "/" + (subpath?.[0] || "");
          return (
            <>
              <a
                class:list={[
                  "font-mono uppercase tracking-widest text-sm transition-all ease-in-out px-2 py-0.5 max-w-fit hover:text-monster hover:border-b hover:border-monster",
                  {
                    "text-monster border-b border-monster": isActive,
                    "text-white/70": !isActive,
                  },
                ]}
                href={link.href ?? `/${href}`}
                target={link.target}
                rel={link.rel}
              >
                {link.title}
              </a>
              <span class="hidden md:block text-monster/40 font-mono">/</span>
            </>
          );
        })
      }
    </div>
  </div>
</nav>

<script>
  window.addEventListener("scroll", () => {
    const logo = document.getElementById("logo");
    if (!logo) return;
    if (window.scrollY > 100) {
      logo.style.textShadow = "none";
    } else {
      logo.style.textShadow = "0 0 12px rgba(0,220,50,0.5)";
    }
  });
</script>
