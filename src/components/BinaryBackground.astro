<canvas id="binary-bg" aria-hidden="true"></canvas>

<script is:inline>
(function () {
  var FONT_SIZE = 13;
  var COL_W = 14;
  var CHARS = ["0", "1"];

  // Module-level state — persists across page-load events
  var rafId = null;
  var resizeTimer = null;
  var canvas = null;
  var ctx = null;
  var cols = 0;
  var drops = null;
  var frameCount = 0;
  var prefersReduced = false;

  function setup() {
    canvas.width = window.innerWidth;
    canvas.height = window.innerHeight;
    cols = Math.floor(canvas.width / COL_W);
    drops = new Float32Array(cols);
    for (var i = 0; i < cols; i++) {
      drops[i] = -(Math.random() * (canvas.height / FONT_SIZE));
    }
  }

  function drawStatic() {
    ctx.clearRect(0, 0, canvas.width, canvas.height);
    ctx.fillStyle = "rgba(0, 220, 50, 0.05)";
    ctx.font = FONT_SIZE + "px 'Share Tech Mono', monospace";
    ctx.textBaseline = "top";
    var rows = Math.ceil(canvas.height / FONT_SIZE);
    for (var c = 0; c < cols; c++) {
      for (var r = 0; r < rows; r++) {
        ctx.fillText(Math.random() < 0.5 ? "0" : "1", c * COL_W, r * FONT_SIZE);
      }
    }
  }

  function tick() {
    rafId = requestAnimationFrame(tick);
    if (document.hidden) return;
    frameCount++;
    if (frameCount % 3 !== 0) return;

    ctx.fillStyle = "rgba(0, 0, 0, 0.04)";
    ctx.fillRect(0, 0, canvas.width, canvas.height);

    ctx.font = FONT_SIZE + "px 'Share Tech Mono', monospace";
    ctx.textBaseline = "top";

    for (var c = 0; c < cols; c++) {
      var y = drops[c] * FONT_SIZE;
      if (y >= 0 && y < canvas.height) {
        var ch = CHARS[Math.floor(Math.random() * 2)];
        if (Math.random() < 0.15) {
          ctx.fillStyle = "rgba(255, 255, 255, 0.6)";
        } else {
          ctx.fillStyle = "rgba(0, 220, 50, 0.85)";
        }
        ctx.fillText(ch, c * COL_W, y);
      }
      drops[c]++;
      if (drops[c] * FONT_SIZE > canvas.height) {
        drops[c] = -(Math.floor(Math.random() * (canvas.height / FONT_SIZE) * 0.6) + 5);
      }
    }
  }

  function startLoop() {
    if (rafId) cancelAnimationFrame(rafId);
    frameCount = 0;
    rafId = requestAnimationFrame(tick);
  }

  function stopLoop() {
    if (rafId) { cancelAnimationFrame(rafId); rafId = null; }
  }

  // Single resize listener for the lifetime of the page
  window.addEventListener("resize", function () {
    clearTimeout(resizeTimer);
    resizeTimer = setTimeout(function () {
      if (!canvas) return;
      stopLoop();
      setup();
      if (prefersReduced) drawStatic();
      else startLoop();
    }, 200);
  }, { passive: true });

  function init() {
    var el = document.getElementById("binary-bg");
    if (!el) return;

    // Cancel any orphaned loop from a previous navigation
    stopLoop();

    canvas = el;
    ctx = canvas.getContext("2d");
    prefersReduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    frameCount = 0;

    setup();

    if (prefersReduced) {
      if (document.fonts && document.fonts.ready) {
        document.fonts.ready.then(drawStatic);
      } else {
        setTimeout(drawStatic, 300);
      }
    } else {
      if (document.fonts && document.fonts.ready) {
        document.fonts.ready.then(startLoop);
      } else {
        setTimeout(startLoop, 300);
      }
    }
  }

  // astro:page-load — fires after every View Transition navigation (including initial load on desktop)
  document.addEventListener("astro:page-load", init);

  // DOMContentLoaded — fallback for mobile browsers (iOS Safari etc.) where
  // astro:page-load timing may be unreliable on first paint.
  // If both events fire, the second init() call just cancels and restarts the
  // loop cleanly via stopLoop() — no visual artefact.
  document.addEventListener("DOMContentLoaded", init);
})();
</script>

<style>
  #binary-bg {
    position: fixed;
    inset: 0;
    width: 100vw;
    height: 100vh;
    z-index: 0;
    pointer-events: none;
    opacity: 0.35;
  }
</style>
