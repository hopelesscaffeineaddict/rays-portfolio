---
type Props = {
  title: string;
  slug: string;
  excerpt: string;
  date: Date;
};

const { title, slug, excerpt, date } = Astro.props;
---

<div
  class="w-full mx-auto relative pb-5 bg-monster/5 backdrop-blur-sm border border-monster/25 rounded-lg overflow-hidden transition-all duration-200 ease-in-out hover:border-monster/70 hover:shadow-monster-sm group"
>
  <!-- Terminal title bar -->
  <div
    class="flex items-center justify-start px-4 py-2 bg-monster/8 border-b border-monster/20"
  >
    <div class="flex space-x-2">
      <div class="w-3 h-3 rounded-full bg-monster/70"></div>
      <div class="w-3 h-3 rounded-full bg-monster/40"></div>
      <div class="w-3 h-3 rounded-full bg-monster/20"></div>
    </div>
  </div>

  <div class="p-6 tracking-wider">
    <a href={`/blog/${slug}`} class="block">
      <h2 class="text-xl font-medium text-white mb-2 uppercase font-mono tracking-widest">
        <span class="text-monster mr-2">❯</span>
        {title}
      </h2>
      <p class="font-mono text-monster/70 tracking-widest text-xs mb-4">
        [{
          date.toLocaleDateString("en-us", {
            year: "numeric",
            month: "short",
            day: "numeric",
          })
        }]
      </p>
      <p class="text-white/60 text-sm font-mono mb-4 line-clamp-1">{excerpt}</p>
      <p
        class="text-monster absolute bottom-4 font-mono text-sm inline-flex items-center underline underline-offset-4 transition-all ease-in-out group-hover:underline-offset-2"
      >
        read more
        <svg
          class="w-4 h-4 ml-2 transform group-hover:translate-x-1 transition-transform"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
          xmlns="http://www.w3.org/2000/svg"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width={2}
            d="M9 5l7 7-7 7"></path>
        </svg>
      </p>
    </a>
  </div>
</div>
