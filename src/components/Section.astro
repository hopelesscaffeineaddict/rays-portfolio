---
type Props = {
  title: string;
  full_screen?: boolean;
  className?: string;
};
const { title = "Section", full_screen = false, className = "" } = Astro.props;
---

<section
  id={title.toLowerCase().replaceAll(" ", "")}
  class={`${full_screen ? "h-screen" : ""} px-4 py-10 w-screen !overflow-x-hidden ${className}`}
>
  <div class="w-full grid place-items-center mb-2">
    <h2
      class="font-monster text-4xl md:text-6xl text-center uppercase tracking-widest text-white"
      style="text-shadow: 0 0 20px rgba(0,220,50,0.35);"
    >
      {`<${title} />`}
    </h2>
    <div class="mt-3 h-px w-24 bg-monster" style="box-shadow: 0 0 8px #00dc32;"></div>
  </div>
  <div class="w-full mt-10 px-4">
    <slot />
  </div>
</section>
